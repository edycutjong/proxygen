# ══════════════════════════════════════════════════════════════
# Proxygen Agent — Environment Variables
# ══════════════════════════════════════════════════════════════
# Copy to .env and fill in values:
#   cp .env.example .env

# ── Mode ─────────────────────────────────────────────────────
# Set to "true" to run with mock data (no API keys needed)
PROXYGEN_DEMO=true

# ── Server ───────────────────────────────────────────────────
# Port for the Fastify API server
PORT=3001
HOST=0.0.0.0

# ── Ace Data Cloud ───────────────────────────────────────────
# Docs: https://platform.acedata.cloud
# No API key needed — x402 payments serve as authentication
ACE_API_URL=https://api.acedata.cloud
# Settlement network: "solana" | "base" | "skale"
ACE_NETWORK=solana

# ── OOBE Protocol / SAP ─────────────────────────────────────
# Get RPC URL from: https://docs.oobeprotocol.ai
# For devnet testing: https://api.devnet.solana.com
OOBE_RPC_URL=https://api.devnet.solana.com
# Cluster: "mainnet-beta" | "devnet" | "localnet"
OOBE_CLUSTER=devnet
# Get API key from: https://dashboard.oobeprotocol.ai
OOBE_API_KEY=sk_your_oobe_api_key_here

# ── Solana Wallet ────────────────────────────────────────────
# Generate with: solana-keygen new --outfile ~/.config/solana/proxygen.json
# Then export base58: solana-keygen pubkey ~/.config/solana/proxygen.json
# Agent wallet needs SOL (gas) + USDC (x402 payments)
SOLANA_PRIVATE_KEY=your_base58_private_key_here

# ── Optional: EVM Wallet (for Base/SKALE x402) ──────────────
# Only needed if ACE_NETWORK=base or ACE_NETWORK=skale
# EVM_PRIVATE_KEY=0xyour_evm_private_key_here

# ── Agent Identity ───────────────────────────────────────────
# x402 endpoint where consumers send payments
# For local dev: http://localhost:3001/x402
# For production: https://proxygen-agent.up.railway.app/x402
AGENT_X402_ENDPOINT=http://localhost:3001/x402

# ── Scraping Configuration ───────────────────────────────────
# Interval between scrape cycles (ms). Default: 600000 (10 min)
SCRAPE_INTERVAL_MS=600000
# Maximum concurrent scrapes per cycle
SCRAPE_MAX_CONCURRENT=3
# How long feed items stay in cache (ms). Default: 3600000 (1 hour)
FEED_TTL_MS=3600000
# Maximum feed items to keep in memory
MAX_FEED_ITEMS=500

# ── LLM Configuration ───────────────────────────────────────
# Primary model for data extraction (via Ace Data Cloud)
LLM_PRIMARY_MODEL=gpt-4o-mini
# Fallback model for cost optimization
LLM_FALLBACK_MODEL=deepseek-v3
# Max tokens per extraction response
LLM_MAX_TOKENS=1000
